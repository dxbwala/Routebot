# API
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
DEVICE_API_KEY_PEPPER=change-me-device-api-key-pepper
WEBHOOK_HMAC_SECRET=change-me-webhook-hmac-secret
MEDIA_STORAGE_PATH=./storage/media
CORS_ORIGINS=*

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=routebot
POSTGRES_PASSWORD=routebot
POSTGRES_DB=routebot
POSTGRES_SSLMODE=disable

# Redis / Valkey
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Device agent defaults
HEARTBEAT_INTERVAL_SECONDS=30
OFFLINE_THRESHOLD_SECONDS=90
