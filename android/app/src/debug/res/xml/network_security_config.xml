<?xml version="1.0" encoding="utf-8"?>
<!-- Debug-only override: allow cleartext HTTP so the agent can be pointed at a
     local/LAN RouteBot API (e.g. http://192.168.x.x) during development.
     Never applied to release builds — see src/main/res/xml for the production config. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
